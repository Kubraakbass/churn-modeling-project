   "source": [
    "from sklearn.metrics import classification_report, roc_auc_score\n",
    "\n",
    "print(classification_report(y_test, y_pred_log))\n",
    "\n",
    "print(\n",
    "    \"ROC-AUC:\",\n",
    "    roc_auc_score(y_test, y_prob_log)\n",
    ")"
   ]
